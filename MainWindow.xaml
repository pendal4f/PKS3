<Window x:Class="PKS3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PKS3 — HTTP Monitoring" Height="820" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource ControlForegroundBrush}">
    <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold"
                   Text="Система мониторинга HTTP-запросов (HttpListener + HttpClient)"/>

        <TabControl Grid.Row="1" Margin="0,10,0,0">
            <TabItem Header="Сервер">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" Grid.Column="0" Margin="0,0,10,0"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <GroupBox Header="Управление" Margin="0,0,0,10">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="Порт:"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Width="120" Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"/>

                                    <Button Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Padding="10,6"
                                            Click="StartStopServer_Click" Content="{Binding ServerButtonText}"/>

                                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0" TextWrapping="Wrap"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               Text="Префикс слушателя: http://localhost:{порт}/ (может потребоваться запуск от администратора или netsh http add urlacl)."/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Статистика" Margin="0,0,0,10">
                                <StackPanel Margin="10" Orientation="Vertical">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Сервер: остановлен">
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock>
                                            <Run Text="Сервер: запущен на "/>
                                            <Hyperlink NavigateUri="{Binding ServerUrl}"
                                                       RequestNavigate="ServerLink_RequestNavigate">
                                                <Run Text="{Binding ServerUrlText}"/>
                                            </Hyperlink>
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,12,8">
                                            <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" Text="GET"/>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding GetCount}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" Text="POST"/>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding PostCount}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" Text="Всего"/>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding TotalCount}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" Text="Среднее, мс"/>
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding AvgMs}"/>
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Margin="0,10,0,6" Foreground="{DynamicResource MutedForegroundBrush}" Text="Таблица статистики"/>
                                    <DataGrid ItemsSource="{Binding ServerStatsTable}" AutoGenerateColumns="False" IsReadOnly="True"
                                              CanUserAddRows="False" HeadersVisibility="None" GridLinesVisibility="Horizontal"
                                              RowHeight="24" MinHeight="100">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Binding="{Binding Value}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Пиковая нагрузка">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource MutedForegroundBrush}" Text="Окно:"/>
                                        <ComboBox Width="120" Margin="8,0,0,0"
                                                  ItemsSource="{Binding LoadChartModes}"
                                                  SelectedItem="{Binding SelectedLoadChartMode, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding LoadPoints}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Width="28" Margin="2,0,2,0" VerticalAlignment="Bottom">
                                                            <Border Height="{Binding Count}" Background="{DynamicResource ChartBarBrush}" CornerRadius="2" ToolTip="{Binding Label}"/>
                                                            <TextBlock FontSize="9" TextAlignment="Center" Foreground="{DynamicResource MutedForegroundBrush}" Text="{Binding Label}" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Width="6"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  ResizeDirection="Columns" ShowsPreview="True"
                                  Background="{DynamicResource BorderBrush}"/>

                    <GroupBox Header="Логи (входящие/исходящие)" Grid.Row="0" Grid.Column="2" Margin="0">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource MutedForegroundBrush}" Text="Фильтр:"/>
                                <ComboBox Width="110" Margin="8,0,0,0" ItemsSource="{Binding MethodFilters}"
                                          SelectedItem="{Binding SelectedMethodFilter, UpdateSourceTrigger=PropertyChanged}"/>
                                <ComboBox Width="130" Margin="8,0,0,0" ItemsSource="{Binding StatusFilters}"
                                          SelectedItem="{Binding SelectedStatusFilter, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Margin="12,0,0,0" Padding="10,4" Click="ClearLogs_Click" Content="Очистить"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding LogsView}" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      RowHeight="26">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Время" Binding="{Binding Timestamp}" Width="170"/>
                                    <DataGridTextColumn Header="Напр." Binding="{Binding Direction}" Width="80"/>
                                    <DataGridTextColumn Header="Метод" Binding="{Binding Method}" Width="70"/>
                                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                                    <DataGridTextColumn Header="Код" Binding="{Binding StatusCode}" Width="70"/>
                                    <DataGridTextColumn Header="мс" Binding="{Binding DurationMs}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>

                    <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Height="6"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  ResizeDirection="Rows" ShowsPreview="True"
                                  Background="{DynamicResource BorderBrush}"/>

                    <GroupBox Header="Текстовый лог (и файл logs.txt)" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBox Margin="10" Text="{Binding LogText}" IsReadOnly="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Клиент">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Запрос" Grid.Row="0" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="URL:"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ClientUrl, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,8,0" VerticalAlignment="Center" Text="Метод:"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Width="120"
                                      ItemsSource="{Binding ClientMethods}"
                                      SelectedItem="{Binding ClientMethod, UpdateSourceTrigger=PropertyChanged}"/>

                            <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Margin="10,0,0,0" Padding="12,8"
                                    Click="SendClientRequest_Click" Content="Отправить"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,8,0" VerticalAlignment="Top" Text="JSON:"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Height="110"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     Text="{Binding ClientJsonBody, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Ответ" Grid.Row="1" Margin="0,0,0,10">
                        <TextBox Margin="10" Height="200" Text="{Binding ClientResponseText}" IsReadOnly="True"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"/>
                    </GroupBox>

                    <GroupBox Header="Подсказки" Grid.Row="2">
                        <StackPanel Margin="10">
                            <TextBlock TextWrapping="Wrap">
                                <Run Text="Примеры:"/>
                                <LineBreak/>
                                <Run Text="1) GET внешний API: https://jsonplaceholder.typicode.com/posts"/>
                                <LineBreak/>
                                <Run Text="2) POST на свой сервер: http://localhost:{порт}/  (тело: { &quot;message&quot;: &quot;hello&quot; })"/>
                                <LineBreak/>
                                <Run Text="3) GET статус своего сервера: http://localhost:{порт}/  (вернёт uptime/счётчики/среднее время)"/>
                                <LineBreak/>
                                <Run Text="4) POST невалидный JSON (ожидаемо 400): http://localhost:{порт}/  (тело: not-json)"/>
                                <LineBreak/>
                                <Run Text="5) Метод не поддерживается (ожидаемо 405): PUT http://localhost:{порт}/"/>
                                <LineBreak/>
                                <Run Text="6) POST с примером сообщения: http://localhost:{порт}/  (тело: { &quot;message&quot;: &quot;Привет, мир!&quot; })"/>
                            </TextBlock>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
